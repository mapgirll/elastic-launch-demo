# ============================================================================
# Elastic Observability Demo Platform — Environment Configuration
# ============================================================================
# Deployment credentials (Elastic URL, API key, Kibana URL, OTLP endpoint)
# are persisted in the app's SQLite database (data/deployments.db) when you
# deploy via the web UI — unless DEMO_CREDENTIALS_LOCKED=1 (see below), in which
# case the server uses DEMO_* variables only and the selector hides credential fields.
#
# This file is for optional app-level overrides only (notification configs,
# port, active scenario, etc.).  Copy to .env and fill in values as needed:
#   cp .env.example .env
# ============================================================================

# ── App Settings ─────────────────────────────────────────────────────────────
# Default scenario to load on startup.
#ACTIVE_SCENARIO=space

# Public demo URL (used in slides page).
#DEMO_URL=/

# Bind address and port for the app server.
#APP_HOST=0.0.0.0
#APP_PORT=80

# ── Locked demo credentials (optional kiosk / shared-host mode) ────────────────
# When DEMO_CREDENTIALS_LOCKED=1, the scenario selector hides Kibana URL + API key
# fields. Launch and test-connection use ONLY the variables below (server-side).
# The API key is never sent to the browser.
#
# DEMO_CREDENTIALS_LOCKED=1
# DEMO_KIBANA_URL=https://your-deployment.kb.region.aws.elastic.cloud
# DEMO_ELASTIC_API_KEY=your_base64_api_key
# Optional if Kibana URL contains .kb. (Elastic Cloud) — ES URL is derived:
# DEMO_ELASTIC_URL=https://your-deployment.es.region.aws.elastic.cloud
# Optional OTLP ingest URL (derived from .kb. → .ingest. if unset):
# DEMO_OTLP_URL=https://your-deployment.ingest.region.aws.elastic.cloud:443
#
# Debian/systemd: put secrets in root-only file, e.g.
#   sudo install -m 600 -o root -g root /path/elastic-demo.env /etc/elastic-launch-demo.env
# Reference from unit: EnvironmentFile=/etc/elastic-launch-demo.env
# Then: sudo systemctl daemon-reload && sudo systemctl restart elastic-launch-demo

# ── Twilio (SMS + Voice Alerts) — Optional ───────────────────────────────────
# Enables SMS and voice call notifications during demos.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# ── Slack (Webhook Alerts) — Optional ────────────────────────────────────────
# Enables Slack channel notifications during demos.
SLACK_WEBHOOK_URL=
